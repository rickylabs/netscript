{
  "version": "0.0.1-beta.2",
  "workspace": [
    "packages/*",
    "packages/cli/e2e",
    "plugins/*",
    "examples/*",
    "apps/*"
  ],
  "exclude": [
    ".llm/tmp/"
  ],
  "unstable": [
    "kv",
    "temporal",
    "tsgo",
    "worker-options"
  ],
  "tasks": {
    "ci": "deno ci && deno task ci:quality && deno task coverage:functions && deno task publish:dry-run && deno task audit:critical",
    "ci:quality": {
      "dependencies": ["check", "lint", "fmt:check", "deps:check"]
    },
    "check": {
      "command": "deno run --allow-read --allow-run .llm/tools/run-deno-check.ts --root packages --root plugins --ext ts,tsx --exclude \"^(packages/(fresh-ui)|.*(?:^|/)\\.generated/|.*(?:^|/)node_modules/)\"",
      "files": [
        "packages/**/*.ts",
        "packages/**/*.tsx",
        "plugins/**/*.ts",
        "plugins/**/*.tsx",
        "deno.json",
        "deno.lock",
        ".llm/tools/run-deno-check.ts"
      ]
    },
    "test": "deno test --allow-all",
    "coverage:functions": "rm -rf .llm/tmp/coverage/functions && deno test --allow-all --coverage=.llm/tmp/coverage/functions --coverage-raw-data-only packages/contracts/tests/errors_test.ts packages/service/tests/_fixtures/readme-examples_test.ts && deno run --allow-read --allow-write .llm/tools/reporting/report-function-coverage.ts --coverage .llm/tmp/coverage/functions --out .llm/tmp/coverage/function-report.json --package packages/contracts --package packages/plugin-triggers-core --package packages/service --package packages/plugin",
    "audit:critical": "deno audit --level critical",
    "deps:latest": "deno run --allow-read --allow-net .llm/tools/deps/latest.ts --pretty --behind-only",
    "deps:outdated": "deno run --allow-read --allow-run .llm/tools/deps/outdated.ts --latest --pretty",
    "deps:why": "deno run --allow-read --allow-run .llm/tools/deps/why.ts",
    "deps:audit": "deno run --allow-read --allow-net --allow-run .llm/tools/deps/audit.ts --level low --pretty",
    "deps:prod-install": "deno run --allow-read --allow-write --allow-net --allow-run --allow-env .llm/tools/deps/prod-install.ts --pretty",
    "deps:census": "deno run --allow-read .llm/tools/deps/census.ts",
    "deps:check": "deno run --allow-read .llm/tools/deps/scan-jsr-centralization.ts --fail-on-violation && deno run --allow-read .llm/tools/deps/audit-file-link.ts --fail-on-violation && deno run --allow-read .llm/tools/deps/scan-npm-catalog-compliance.ts",
    "deps:check:npm-catalog": "deno run --allow-read .llm/tools/deps/scan-npm-catalog-compliance.ts",
    "deps:check:jsr-centralization": "deno run --allow-read .llm/tools/deps/scan-jsr-centralization.ts",
    "deps:audit:file-link": "deno run --allow-read .llm/tools/deps/audit-file-link.ts",
    "version:bump": "deno run --allow-read --allow-run --allow-env .llm/tools/deps/bump-version.ts",
    "version:bump:test": "deno test --allow-read --allow-write --allow-run --allow-env .llm/tools/deps/bump-version_test.ts",
    "agentic:sync-claude": "deno run --no-lock --allow-read --allow-write .llm/tools/agentic/sync-claude-skills.ts --pretty",
    "agentic:sync-claude:check": "deno run --no-lock --allow-read .llm/tools/agentic/sync-claude-skills.ts --check --pretty",
    "agentic:check-claude": "deno run --no-lock --allow-read --allow-run .llm/tools/agentic/validate-claude-surface.ts --pretty",
    "docs:links": "deno run --no-lock --allow-read .llm/tools/validation/check-internal-doc-links.ts --pretty",
    "docs:maintenance": "deno task docs:links && deno task agentic:sync-claude:check && deno task agentic:check-claude",
    "agentic:smoke-claude-remote": "deno run --no-lock --allow-read --allow-run .llm/tools/agentic/claude-remote-smoke.ts --env-aware --pretty",
    "agentic:codex-resume": "deno run --no-lock --allow-read --allow-run .llm/tools/agentic/codex-resume.ts",
    "agentic:codex-status": "deno run --no-lock --allow-run .llm/tools/agentic/codex-status.ts",
    "agentic:codex-watch": "deno run --no-lock --allow-read --allow-run --allow-env .llm/tools/agentic/codex-watch.ts",
    "agentic:launch-codex-slice": "deno run --no-lock --allow-read --allow-write --allow-run .llm/tools/agentic/launch-codex-slice.ts",
    "agentic:dispatch-openhands": "deno run --no-lock --allow-read --allow-env --allow-net .llm/tools/agentic/dispatch-openhands.ts",
    "agentic:openhands-status": "deno run --no-lock --allow-read --allow-env --allow-net .llm/tools/agentic/openhands-status.ts",
    "agentic:gh-pr": "deno run --no-lock --allow-read --allow-env --allow-net .llm/tools/agentic/gh-pr.ts",
    "agentic:gh-watch": "deno run --no-lock --allow-env --allow-net .llm/tools/agentic/gh-watch.ts",
    "agentic:gh-token": "deno run --no-lock --allow-run --allow-env --allow-net .llm/tools/agentic/gh-token.ts",
    "agentic:claude-hook-log": "deno run --no-lock --allow-env --allow-write .llm/tools/agentic/claude-hook-log.ts",
    "gen:assets-barrel": "deno run --no-lock --allow-read --allow-write --allow-run=deno .llm/tools/generate-cli-assets-barrel.ts",
    "check:assets-barrel": "deno task gen:assets-barrel && git diff --exit-code -- packages/cli/src/kernel/assets/embedded.generated.ts packages/plugin/src/kernel/assets/embedded.generated.ts packages/fresh-ui/registry.generated.ts packages/service/src/primitives/scalar.generated.ts",
    "check:scaffold-versions": "deno run .llm/tools/validation/check-scaffold-versions.ts --pretty",
    "release:preflight": "deno run --allow-read .llm/tools/release/preflight-text-imports.ts",
    "release:cut": "deno run --allow-read --allow-write --allow-run --allow-env .llm/tools/release/cut.ts",
    "release:publish": "deno run --allow-net --allow-env --allow-run --allow-read .llm/tools/release/github-release.ts",
    "publish:dry-run": "deno run --allow-read --allow-write --allow-run .llm/tools/release/run-publish-dry-run.ts",
    "doc:lint": "deno run --allow-read --allow-run .llm/tools/run-deno-doc-lint.ts",
    "e2e:cli": "deno run --allow-all packages/cli/e2e/cli.ts",
    "e2e:cli:prod": "deno run --allow-all packages/cli/e2e/cli.ts run scaffold.runtime --source jsr --cli packages/cli/bin/netscript.ts",
    "bench:self": "deno run --allow-all packages/bench/cli.ts self",
    "bench:self:fake": "deno run --allow-all packages/bench/cli.ts self --fake",
    "bench:conformance": "deno run --allow-all packages/bench/cli.ts conformance",
    "fmt": "deno run --allow-read --allow-run .llm/tools/run-deno-fmt.ts --root packages --root plugins --ext ts,tsx --exclude \"^(packages/(cli)|.*(?:^|/)\\.generated/|.*(?:^|/)node_modules/)\" --write",
    "fmt:check": {
      "command": "deno run --allow-read --allow-run .llm/tools/run-deno-fmt.ts --root packages --root plugins --ext ts,tsx --exclude \"^(packages/(cli)|.*(?:^|/)\\.generated/|.*(?:^|/)node_modules/)\" --ignore-line-endings",
      "files": [
        "packages/**/*.ts",
        "packages/**/*.tsx",
        "plugins/**/*.ts",
        "plugins/**/*.tsx",
        "deno.json",
        ".llm/tools/run-deno-fmt.ts"
      ]
    },
    "lint": {
      "command": "deno run --allow-read --allow-run .llm/tools/run-deno-lint.ts --root packages --root plugins --ext ts,tsx --exclude \"^(packages/(fresh-ui|cli)|.*(?:^|/)\\.generated/|.*(?:^|/)node_modules/)\"",
      "files": [
        "packages/**/*.ts",
        "packages/**/*.tsx",
        "plugins/**/*.ts",
        "plugins/**/*.tsx",
        "deno.json",
        ".llm/tools/run-deno-lint.ts"
      ]
    },
    "docs:readme:check": "deno run --no-lock --allow-read .llm/tools/validation/check-readme-standard.ts --pretty",
    "arch:check": "deno task deps:check && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/plugin-auth-core && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/auth-workos && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/auth-better-auth && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/auth-kv-oauth && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root plugins/auth && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/plugin && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root plugins/workers && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root plugins/sagas && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root plugins/triggers && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root plugins/streams && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/plugin-sagas-core && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/plugin-triggers-core && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/plugin-workers-core && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/plugin-ai-core && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root packages/ai && deno run --allow-read .llm/tools/fitness/check-doctrine.ts --root plugins/ai",
    "arch:check:repo": "deno run --allow-read .llm/tools/fitness/check-doctrine.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "isolatedDeclarations": true,
    "lib": [
      "dom",
      "deno.ns",
      "deno.unstable"
    ]
  },
  "lint": {
    "exclude": [
      ".llm/",
      "tools/",
      "packages/cli/"
    ],
    "rules": {
      "tags": [
        "recommended",
        "jsr"
      ],
      "include": [
        "no-process-global",
        "no-node-globals"
      ]
    }
  },
  "fmt": {
    "include": [
      "packages/**/*.ts",
      "packages/**/*.tsx",
      "plugins/**/*.ts",
      "plugins/**/*.tsx"
    ],
    "exclude": [
      "packages/cli/",
      "**/.generated/",
      "**/node_modules/"
    ],
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  },
  "publish": false,
  "catalog": {
    "@durable-streams/client": "^0.2.6",
    "@durable-streams/server": "^0.3.7",
    "@durable-streams/state": "^0.3.1",
    "@opentelemetry/api": "^1.9.1",
    "@orpc/client": "^1.14.6",
    "@orpc/contract": "^1.14.6",
    "@orpc/openapi": "^1.14.6",
    "@orpc/server": "^1.14.6",
    "@orpc/tanstack-query": "^1.14.6",
    "@orpc/zod": "^1.14.6",
    "@preact/signals": "2.9.2",
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/driver-adapter-utils": "^7.8.0",
    "@prisma/instrumentation-contract": "^7.8.0",
    "@workos-inc/node": "^10.4.0",
    "@saga-bus/core": "^0.2.2",
    "@tanstack/db": "^0.6.8",
    "@tanstack/preact-query": "^5.101.0",
    "@tanstack/query-core": "^5.101.0",
    "@tanstack/query-db-collection": "^1.0.40",
    "@tanstack/react-db": "^0.1.86",
    "@tailwindcss/vite": "^4.3.1",
    "amqplib": "^2.0.1",
    "better-auth": "^1.6.20",
    "clsx": "^2.1.1",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "preact": "^10.29.2",
    "preact-render-to-string": "^6.7.0",
    "tailwindcss": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "vite": "7.2.2"
  }
}
