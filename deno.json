{
  "version": "0.0.1-alpha.0",
  "workspace": [
    "packages/*",
    "packages/cli/e2e",
    "plugins/*",
    "examples/*",
    "apps/*"
  ],
  "exclude": [
    ".llm/tmp/"
  ],
  "unstable": [
    "kv",
    "temporal",
    "tsgo",
    "worker-options",
    "raw-imports"
  ],
  "tasks": {
    "check": "deno run --allow-read --allow-run .llm/tools/run-deno-check.ts --root packages --root plugins --ext ts,tsx --exclude \"^(packages/(fresh-ui)|.*(?:^|/)\\.generated/|.*(?:^|/)node_modules/)\"",
    "test": "deno test --allow-all",
    "publish:dry-run": "deno publish --dry-run --allow-dirty",
    "e2e:cli": "deno run --allow-all packages/cli/e2e/cli.ts",
    "fmt": "deno run --allow-read --allow-run .llm/tools/run-deno-fmt.ts --root packages --root plugins --ext ts,tsx --exclude \"^(packages/(cli)|.*(?:^|/)\\.generated/|.*(?:^|/)node_modules/)\" --write",
    "fmt:check": "deno run --allow-read --allow-run .llm/tools/run-deno-fmt.ts --root packages --root plugins --ext ts,tsx --exclude \"^(packages/(cli)|.*(?:^|/)\\.generated/|.*(?:^|/)node_modules/)\" --ignore-line-endings",
    "lint": "deno run --allow-read --allow-run .llm/tools/run-deno-lint.ts --root packages --root plugins --ext ts,tsx --exclude \"^(packages/(fresh-ui|cli)|.*(?:^|/)\\.generated/|.*(?:^|/)node_modules/)\"",
    "arch:check": "deno run --allow-read .llm/tools/fitness/check-doctrine.ts"
  },
  "imports": {},
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "isolatedDeclarations": true,
    "lib": [
      "dom",
      "deno.ns",
      "deno.unstable"
    ]
  },
  "lint": {
    "exclude": [
      ".llm/",
      "tools/",
      "packages/cli/"
    ],
    "rules": {
      "tags": [
        "recommended",
        "jsr"
      ],
      "include": [
        "no-process-global",
        "no-node-globals"
      ]
    }
  },
  "fmt": {
    "include": [
      "packages/**/*.ts",
      "packages/**/*.tsx",
      "plugins/**/*.ts",
      "plugins/**/*.tsx"
    ],
    "exclude": [
      "packages/cli/",
      "**/.generated/",
      "**/node_modules/"
    ],
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  },
  "publish": false,
  "catalog": {
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/server": "^0.2.3",
    "@durable-streams/state": "^0.2.3",
    "@opentelemetry/api": "^1.9.0",
    "@orpc/client": "^1.13.5",
    "@orpc/contract": "^1.13.5",
    "@orpc/openapi": "^1.13.5",
    "@orpc/server": "^1.13.5",
    "@orpc/tanstack-query": "^1.13.5",
    "@orpc/zod": "^1.13.5",
    "@preact/signals": "^2.5.0",
    "@prisma/adapter-mssql": "^7.4.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@prisma/driver-adapter-utils": "^7.4.2",
    "@prisma/instrumentation-contract": "^7.4.2",
    "@saga-bus/core": "^0.2.2",
    "@standard-schema/spec": "^1.1.0",
    "@tanstack/db": "^0.6.1",
    "@tanstack/preact-query": "^5.75.5",
    "@tanstack/query-core": "^5.75.5",
    "@tanstack/query-db-collection": "^1.0.32",
    "@tanstack/react-db": "^0.1.79",
    "amqplib": "^0.10.4",
    "clsx": "^2.1.1",
    "hono": "^4.10.6",
    "ioredis": "^5.4.1",
    "mysql2": "^3.22.3",
    "pg": "^8.13.1",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.5",
    "tailwind-merge": "^3.5.0",
    "vite": "7.2.2",
    "zod": "^4.3.6"
  }
}
