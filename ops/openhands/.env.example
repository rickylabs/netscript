OPENHANDS_IMAGE=docker.openhands.dev/openhands/openhands:1.6
OPENHANDS_PORT=3000
SANDBOX_RUNTIME_CONTAINER_IMAGE=docker.all-hands.dev/all-hands-ai/runtime:0.39-nikolaik
LOG_ALL_EVENTS=true

# LiteLLM-compatible model settings.
LLM_MODEL=anthropic/claude-sonnet-4
LLM_BASE_URL=
LLM_API_KEY=

# Use a dedicated bot PAT or GitHub App token when sessions should trigger follow-up workflows.
GITHUB_TOKEN=
