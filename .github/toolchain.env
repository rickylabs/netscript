# Shared CI/agent toolchain pins for NetScript.
#
# Keep these aligned with package scaffold constants, templates, and installable
# tool releases. OpenHands PR-comment runs hydrate this file from the workflow
# ref, so fixes here affect old PR branches as soon as the workflow is merged to
# main.
NETSCRIPT_DENO_VERSION=v2.9.0
NETSCRIPT_DOTNET_VERSION=10.0.x
NETSCRIPT_DOTNET_CHANNEL=10.0
NETSCRIPT_ASPIRE_CLI_VERSION=13.4.0
NETSCRIPT_ASPIRE_SDK_VERSION=13.4.4
