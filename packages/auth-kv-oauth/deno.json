{
  "name": "@netscript/auth-kv-oauth",
  "version": "0.0.1-alpha.11",
  "description": "KV-backed OAuth2/OIDC AuthBackendPort backend for NetScript auth.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./providers": "./src/providers.ts",
    "./store": "./src/store.ts",
    "./crypto": "./src/crypto.ts",
    "./cookies": "./src/cookies.ts",
    "./flow": "./src/flow.ts",
    "./backend": "./src/backend.ts",
    "./errors": "./src/errors.ts"
  },
  "imports": {
    "@panva/oauth4webapi": "jsr:@panva/oauth4webapi@^3.8.6",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "check": "deno check --unstable-kv ./mod.ts",
    "test": "deno test --unstable-kv --allow-all ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "mod.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  }
}
