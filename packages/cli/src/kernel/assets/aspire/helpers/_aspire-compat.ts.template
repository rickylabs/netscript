// ============================================================================
// Path helpers
// ============================================================================

export function resolveWorkspacePath(
  appHostDir: string,
  relativePath: string,
): string {
  return resolve(appHostDir, relativePath);
}

export function resolveDataPath(
  appHostDir: string,
  dataPath: string | undefined,
  resourceName: string,
): string {
  const relativePath = dataPath ?? join('.data', resourceName);
  return resolveWorkspacePath(appHostDir, relativePath);
}

// ============================================================================
// Database environment helpers
// ============================================================================

export function buildDatabaseUriEnvKey(config: Pick<NetScriptConfig, 'PrimaryDatabase'>): string | null {
  if (!config.PrimaryDatabase) {
    return null;
  }

  const prefix = config.PrimaryDatabase
    .replace(/[^a-z0-9]+/gi, '_')
    .replace(/^_+|_+$/g, '')
    .toUpperCase();
  return prefix ? `${prefix}_URI` : null;
}

// ============================================================================
// Permission resolution
// ============================================================================

export function resolvePermissions(
  entryPermissions: readonly string[] | undefined,
  defaultPermissions: readonly string[],
  watchMode: boolean = false,
  watchFlag: string = RESOURCE_DEFAULTS.WatchHmrFlag,
): string[] {
  const base = entryPermissions ? [...entryPermissions] : [...defaultPermissions];
  if (watchMode) {
    base.push(watchFlag);
  }
  return base;
}

// ============================================================================
// VITE environment variables
// ============================================================================

export interface ViteEnvVarNames {
  readonly full: string;
  readonly shorthand: string;
}

export function buildViteEnvVarName(
  resourceName: string,
  endpointName: string = RESOURCE_DEFAULTS.HttpEndpointName,
): ViteEnvVarNames {
  const full = `VITE_services__${resourceName}__${endpointName}__0`;
  const normalised = resourceName.toUpperCase().replace(/-/g, '_');
  const shorthand = `VITE_${normalised}_URL`;

  return { full, shorthand };
}

