/**
 * Seed script for the scaffolded database workspace.
 *
 * @module
 */

import { db } from '../mod.ts';

if (import.meta.main) {
  const client = await db.getClient();

  try {
    await client.$queryRaw`SELECT 1`;
    console.log('✅ Database seed completed.');
  } finally {
    await db.disconnect();
  }
}
