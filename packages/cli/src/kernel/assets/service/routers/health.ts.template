/**
 * Health check router — implements the {{serviceName | pascalCase}} service's
 * v1 health contract.
 */

import { v1 } from '@{{projectName}}/contracts';

const startTime = Date.now();

export const health = {
  check: v1.{{serviceName | camelCase}}.health.check.handler(async () => ({
    status: 'healthy' as const,
    service: '{{serviceName}}',
    version: '1.0.0',
    timestamp: new Date().toISOString(),
    uptime: Math.floor((Date.now() - startTime) / 1000),
  })),
};
