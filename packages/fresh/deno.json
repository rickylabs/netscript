{
  "name": "@netscript/fresh",
  "version": "0.0.1-beta.6",
  "description": "Fresh runtime extensions, builders, forms, defer primitives, and route contracts for NetScript.",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts",
    "./server": "./src/runtime/server/mod.ts",
    "./builders": "./src/application/builders/mod.ts",
    "./route": "./src/application/route/mod.ts",
    "./defer": "./src/application/defer/mod.ts",
    "./form": "./src/application/form/mod.ts",
    "./error": "./src/diagnostics/error/mod.ts",
    "./streams": "./src/runtime/streams/mod.ts",
    "./ai": "./src/runtime/ai/mod.ts",
    "./ai/sandbox": "./src/runtime/ai/sandbox.ts",
    "./query": "./src/application/query/mod.ts",
    "./interactive": "./src/runtime/interactive/mod.ts",
    "./vite": "./src/application/vite/vite.ts",
    "./testing": "./src/testing/mod.ts"
  },
  "tasks": {
    "test": "deno test --allow-all ./src ./tests",
    "check": "deno check --unstable-kv ./mod.ts ./src/runtime/server/mod.ts ./src/application/builders/mod.ts ./src/application/route/mod.ts ./src/application/query/mod.ts ./src/application/vite/vite.ts ./src/runtime/interactive/mod.ts ./src/application/defer/mod.ts ./src/application/form/mod.ts ./src/diagnostics/error/mod.ts ./src/runtime/streams/mod.ts ./src/runtime/ai/mod.ts ./src/runtime/ai/sandbox.ts ./src/testing/mod.ts",
    "doc-lint": "deno doc --lint ./mod.ts ./src/runtime/server/mod.ts ./src/application/builders/mod.ts ./src/application/route/mod.ts ./src/application/defer/mod.ts ./src/application/form/mod.ts ./src/diagnostics/error/mod.ts ./src/runtime/streams/mod.ts ./src/runtime/ai/mod.ts ./src/runtime/ai/sandbox.ts ./src/application/query/mod.ts ./src/runtime/interactive/mod.ts ./src/application/vite/vite.ts ./src/testing/mod.ts",
    "fmt": "deno fmt ./mod.ts ./src ./tests/_fixtures",
    "fmt:check": "deno fmt --check ./mod.ts ./src ./tests/_fixtures",
    "lint": "deno lint --rules-exclude=no-slow-types ./mod.ts ./src ./tests/_fixtures",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/http": "jsr:@std/http@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/text": "jsr:@std/text@^1",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.2",
    "preact-render-to-string": "npm:preact-render-to-string@^6.7.0",
    "zod": "jsr:@zod/zod@4.4.3",
    "@durable-streams/state": "npm:@durable-streams/state@^0.3.1",
    "@durable-streams/tanstack-ai-transport": "npm:@durable-streams/tanstack-ai-transport@^0.0.8",
    "@netscript/ai": "jsr:@netscript/ai@0.0.1-beta.6",
    "@netscript/telemetry": "jsr:@netscript/telemetry@0.0.1-beta.6",
    "@tanstack/ai": "npm:@tanstack/ai@^0.39.0",
    "@tanstack/ai-preact": "npm:@tanstack/ai-preact@^0.10.1"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*_test.tsx",
      "**/*.test.ts",
      "**/*.test.tsx"
    ]
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  }
}
