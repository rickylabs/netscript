{
  "name": "@netscript/fresh",
  "version": "0.0.1-alpha.0",
  "description": "Fresh runtime extensions, builders, forms, defer primitives, and route contracts for NetScript.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./server": "./src/runtime/server/mod.ts",
    "./builders": "./src/application/builders/mod.ts",
    "./route": "./src/application/route/mod.ts",
    "./defer": "./src/application/defer/mod.ts",
    "./form": "./src/application/form/mod.ts",
    "./error": "./src/diagnostics/error/mod.ts",
    "./streams": "./src/runtime/streams/mod.ts",
    "./query": "./src/application/query/mod.ts",
    "./interactive": "./src/runtime/interactive/mod.ts",
    "./vite": "./src/application/vite/vite.ts",
    "./testing": "./src/testing/mod.ts"
  },
  "tasks": {
    "test": "deno test --allow-all ./src ./tests",
    "check": "deno check --unstable-kv ./mod.ts ./server.ts ./builders/mod.ts ./route/mod.ts ./query/mod.ts ./config/vite.ts ./src/runtime/interactive/mod.ts ./src/application/defer/mod.ts ./src/application/form/mod.ts ./src/diagnostics/error/mod.ts ./src/runtime/streams/mod.ts ./src/testing/mod.ts",
    "doc-lint": "deno doc --lint ./mod.ts ./src/runtime/server/mod.ts ./src/application/builders/mod.ts ./src/application/route/mod.ts ./src/application/defer/mod.ts ./src/application/form/mod.ts ./src/diagnostics/error/mod.ts ./src/runtime/streams/mod.ts ./src/application/query/mod.ts ./src/runtime/interactive/mod.ts ./src/application/vite/vite.ts ./src/testing/mod.ts",
    "fmt": "deno fmt ./mod.ts ./server.ts ./builders/mod.ts ./route/mod.ts ./query/mod.ts ./config/vite.ts ./src ./tests/_fixtures",
    "fmt:check": "deno fmt --check ./mod.ts ./server.ts ./builders/mod.ts ./route/mod.ts ./query/mod.ts ./config/vite.ts ./src ./tests/_fixtures",
    "lint": "deno lint --rules-exclude=no-slow-types ./mod.ts ./server.ts ./builders/mod.ts ./route/mod.ts ./query/mod.ts ./config/vite.ts ./src ./tests/_fixtures",
    "dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@netscript/plugin-streams-core": "../plugin-streams-core/mod.ts",
    "@netscript/logger": "../logger/mod.ts",
    "@netscript/sdk": "../sdk/mod.ts",
    "@netscript/sdk/query-client": "../sdk/src/query-client/mod.ts",
    "@netscript/telemetry": "../telemetry/mod.ts",
    "@preact/signals": "npm:@preact/signals@^2.3.2",
    "@tanstack/preact-query": "npm:@tanstack/preact-query@^5.75.5",
    "@tanstack/query-core": "npm:@tanstack/query-core@^5.75.5",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/http": "jsr:@std/http@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/text": "jsr:@std/text@^1",
    "fresh": "jsr:@fresh/core@^2.3.0",
    "preact": "npm:preact@^10.29.1",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.5",
    "vite": "npm:vite@7.2.2",
    "zod": "npm:zod@^4.3.6",
    "@durable-streams/state": "npm:@durable-streams/state@^0.2.3",
    "@tanstack/react-db": "npm:@tanstack/react-db@^0.1.79"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "deno.json",
      "README.md",
      "docs/**/*.md"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*_test.tsx",
      "**/*.test.ts",
      "**/*.test.tsx"
    ]
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  }
}
