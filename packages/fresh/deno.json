{
  "name": "@netscript/fresh",
  "version": "0.0.1-alpha.0",
  "description": "Fresh runtime extensions, builders, forms, defer primitives, and route contracts for NetScript.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./server": "./server.ts",
    "./builders": "./builders/mod.ts",
    "./route": "./route/mod.ts",
    "./defer": "./defer/mod.ts",
    "./form": "./form/mod.ts",
    "./error": "./error/mod.ts",
    "./utils": "./utils/mod.ts",
    "./streams": "./streams/mod.ts",
    "./query": "./query/mod.ts",
    "./interactive": "./interactive.ts",
    "./vite": "./config/vite.ts",
    "./testing": "./testing.ts"
  },
  "tasks": {
"test": "deno test --allow-all ./builders ./config ./defer ./form ./interactive ./route ./server ./utils ./error ./tests",
    "check": "deno check --unstable-kv ./mod.ts ./interactive.ts ./server.ts ./builders/mod.ts ./route/mod.ts ./defer/mod.ts ./form/mod.ts ./error/mod.ts ./utils/mod.ts ./streams/mod.ts ./query/mod.ts ./config/vite.ts ./testing.ts",
    "doc-lint": "deno doc --lint ./mod.ts ./interactive.ts ./server.ts ./builders/mod.ts ./route/mod.ts ./defer/mod.ts ./form/mod.ts ./error/mod.ts ./utils/mod.ts ./streams/mod.ts ./query/mod.ts ./config/vite.ts ./testing.ts",
    "fmt": "deno fmt ./mod.ts ./interactive.ts ./interactive ./error ./utils ./config ./_internal ./testing.ts ./tests/_fixtures",
    "fmt:check": "deno fmt --check ./mod.ts ./interactive.ts ./interactive ./error ./utils ./config ./_internal ./testing.ts ./tests/_fixtures",
    "lint": "deno lint --rules-exclude=no-slow-types ./mod.ts ./interactive.ts ./interactive ./error ./utils ./config ./_internal ./testing.ts ./tests/_fixtures",
    "dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@netscript/plugin-streams-core": "../plugin-streams-core/mod.ts",
    "@netscript/logger": "../logger/mod.ts",
    "@netscript/sdk": "../sdk/mod.ts",
    "@netscript/sdk/query-client": "../sdk/query-client/mod.ts",
    "@netscript/telemetry": "../telemetry/mod.ts",
    "@preact/signals": "npm:@preact/signals@^2.3.2",
    "@tanstack/preact-query": "npm:@tanstack/preact-query@^5.75.5",
    "@tanstack/query-core": "npm:@tanstack/query-core@^5.75.5",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/http": "jsr:@std/http@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/text": "jsr:@std/text@^1",
    "fresh": "jsr:@fresh/core@^2.3.0",
    "preact": "npm:preact@^10.29.1",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.5",
    "vite": "npm:vite@7.2.2",
    "zod": "npm:zod@^4.3.6",
    "@durable-streams/state": "npm:@durable-streams/state@^0.2.3",
    "@tanstack/react-db": "npm:@tanstack/react-db@^0.1.79"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "deno.json",
      "README.md",
      "docs/**/*.md"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*_test.tsx",
      "**/*.test.ts",
      "**/*.test.tsx"
    ]
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  }
}
