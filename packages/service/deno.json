{
  "name": "@netscript/service",
  "version": "0.0.1-beta.3",
  "description": "Service bootstrap builders, health probes, and Hono/oRPC runtime wiring for NetScript applications.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./auth": "./src/auth/mod.ts"
  },
  "tasks": {
    "check": "deno check --unstable-kv ./mod.ts",
    "test": "deno test --allow-all ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty --allow-slow-types"
  },
  "imports": {
    "hono": "jsr:@hono/hono@4.12.24",
    "hono/cors": "jsr:@hono/hono@4.12.24/cors",
    "hono/logger": "jsr:@hono/hono@4.12.24/logger",
    "@orpc/server": "npm:@orpc/server@^1.14.6",
    "@orpc/openapi": "npm:@orpc/openapi@^1.14.6",
    "@orpc/client": "npm:@orpc/client@^1.14.6",
    "@orpc/zod": "npm:@orpc/zod@^1.14.6",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "publish": {
    "include": [
      "mod.ts",
      "src/**/*.ts",
      "README.md",
      "deno.json"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  }
}
