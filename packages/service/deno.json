{
  "name": "@netscript/service",
  "version": "0.0.1-alpha.0",
  "description": "Service bootstrap builders, health probes, and Hono/oRPC runtime wiring for NetScript applications.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts"
  },
  "tasks": {
    "check": "deno check --unstable-kv ./mod.ts",
    "test": "deno test --allow-all ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty --allow-slow-types"
  },
  "imports": {
    "hono": "catalog:",
    "hono/cors": "npm:hono@^4.10.6/cors",
    "hono/logger": "npm:hono@^4.10.6/logger",
    "@orpc/openapi": "catalog:",
    "@orpc/openapi/fetch": "npm:@orpc/openapi@^1.14.6/fetch",
    "@orpc/server": "catalog:",
    "@orpc/server/fetch": "npm:@orpc/server@^1.14.6/fetch",
    "@orpc/server/plugins": "npm:@orpc/server@^1.14.6/plugins",
    "@orpc/client/plugins": "npm:@orpc/client@^1.14.6/plugins",
    "@orpc/zod": "catalog:",
    "@orpc/zod/zod4": "npm:@orpc/zod@^1.14.6/zod4",
    "@netscript/telemetry": "../telemetry/mod.ts",
    "@netscript/logger": "../logger/mod.ts",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "publish": {
    "include": [
      "mod.ts",
      "src/**/*.ts",
      "assets/scalar.min.js",
      "README.md",
      "docs/**/*.md",
      "deno.json"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  }
}
