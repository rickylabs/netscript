{
  "name": "@netscript/queue",
  "version": "0.0.1-beta.3",
  "description": "Provider-agnostic message queue abstraction wrapping Fedify adapters for Deno KV, Redis, and RabbitMQ.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./adapters/deno-kv": "./adapters/deno-kv.adapter.ts",
    "./adapters/redis": "./adapters/redis.adapter.ts",
    "./adapters/amqp": "./adapters/amqp.adapter.ts",
    "./adapters/postgres": "./adapters/postgres.adapter.ts",
    "./adapters/kv-dead-letter-store": "./adapters/kv-dead-letter-store.ts",
    "./adapters/postgres-dead-letter-store": "./adapters/postgres-dead-letter-store.ts",
    "./adapters/redis-dead-letter-store": "./adapters/redis-dead-letter-store.ts",
    "./adapters/kv-polling": "./adapters/kv-polling.adapter.ts",
    "./ports": "./ports/mod.ts",
    "./errors": "./ports/errors.ts",
    "./validation": "./validation/mod.ts",
    "./testing": "./testing/mod.ts"
  },
  "tasks": {
    "check": "deno check ./mod.ts ./ports/mod.ts ./ports/errors.ts ./validation/mod.ts ./testing/mod.ts ./adapters/deno-kv.adapter.ts ./adapters/redis.adapter.ts ./adapters/amqp.adapter.ts ./adapters/postgres.adapter.ts ./adapters/kv-dead-letter-store.ts ./adapters/postgres-dead-letter-store.ts ./adapters/redis-dead-letter-store.ts ./adapters/kv-polling.adapter.ts",
    "test": "deno test ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@fedify/fedify": "jsr:@fedify/fedify@^2.2.5",
    "@fedify/denokv": "jsr:@fedify/denokv@^2.2.5",
    "@fedify/redis": "jsr:@fedify/redis@^2.2.5",
    "@fedify/amqp": "jsr:@fedify/amqp@^2.2.5",
    "zod": "jsr:@zod/zod@4.4.3",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/async": "jsr:@std/async@^1"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  }
}
