{
  "name": "@netscript/runtime-config",
  "version": "0.0.1-alpha.4",
  "license": "MIT",
  "description": "Hot-reloadable NetScript runtime override types, loaders, watchers, and diagnostics.",
  "exports": {
    ".": "./mod.ts"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "mod.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "tests/**",
      "examples/**"
    ]
  },
  "tasks": {
    "check": "deno check mod.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  }
}
