{
  "name": "@netscript/fresh-ui",
  "version": "0.0.1-alpha.1",
  "description": "Fresh UI registry seams and interactive foundations for NetScript.",
  "license": "MIT",
  "exclude": [],
  "exports": {
    ".": "./mod.ts",
    "./interactive": "./interactive.ts",
    "./primitives": "./primitives.tsx"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "preact/hooks": "npm:preact@^10.29.2/hooks",
    "preact/jsx-runtime": "npm:preact@^10.29.2/jsx-runtime"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.css",
      "registry/**/*.json",
      "docs/**/*.md",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.css",
      "!registry/**/*.json",
      "!docs/**/*.md",
      "!deno.json",
      "!README.md",
      "scripts/**",
      "tests/**"
    ]
  },
  "tasks": {
    "check": "deno check --lock=deno.lock --unstable-kv \"**/*.ts\" \"**/*.tsx\"",
    "test": "deno test --lock=deno.lock --unstable-kv \"tests/**/*.ts\" \"tests/**/*.tsx\"",
    "tokens:build": "deno run --lock=deno.lock --allow-read=. --allow-write=registry/theme --allow-env --allow-net=registry.npmjs.org scripts/build-tokens.ts",
    "tokens:check": "deno task tokens:build && git diff --exit-code registry/theme/tokens.css registry/theme/theme-bridge.css registry/theme/tokens.json"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  },
  "fmt": {
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.css",
      "**/*.md"
    ],
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  }
}
