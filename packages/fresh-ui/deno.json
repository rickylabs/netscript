{
  "name": "@netscript/fresh-ui",
  "version": "0.0.1-alpha.0",
  "description": "Fresh UI registry seams and interactive foundations for NetScript.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./interactive": "./interactive.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "clsx": "npm:clsx@^2.1.1",
    "preact": "npm:preact@^10.27.2",
    "preact/hooks": "npm:preact@^10.27.2/hooks",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "tailwind-merge": "npm:tailwind-merge@^3.5.0"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.css",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "scripts/**",
      "**/*_test.ts",
      "**/*_test.tsx",
      "**/*.test.ts",
      "**/*.test.tsx"
    ]
  },
  "tasks": {
    "check": "deno check --config deno.gates.json --no-lock --unstable-kv \"**/*.ts\" \"**/*.tsx\"",
    "test": "deno test --config deno.gates.json --no-lock --unstable-kv \"**/*_test.ts\" \"**/*_test.tsx\" \"**/*.test.ts\" \"**/*.test.tsx\"",
    "tokens:build": "deno run --no-lock --allow-read=. --allow-write=registry/theme/tokens.css --allow-env --allow-net=registry.npmjs.org scripts/build-tokens.ts",
    "tokens:check": "deno task tokens:build && git diff --exit-code registry/theme/tokens.css"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ]
  }
}
