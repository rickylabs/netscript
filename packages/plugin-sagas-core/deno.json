{
  "name": "@netscript/plugin-sagas-core",
  "version": "0.0.1-canary.1",
  "description": "Saga DSL, runtime ports, adapters, telemetry, config, and testing primitives for NetScript sagas plugins.",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts",
    "./builders": "./src/builders/mod.ts",
    "./domain": "./src/domain/mod.ts",
    "./ports": "./src/ports/mod.ts",
    "./runtime": "./src/runtime/mod.ts",
    "./adapters": "./src/adapters/mod.ts",
    "./transports": "./src/transports/mod.ts",
    "./stores": "./src/stores/mod.ts",
    "./middleware": "./src/middleware/mod.ts",
    "./integration/workers": "./src/integration/workers/mod.ts",
    "./integration/publisher": "./src/integration/publisher/mod.ts",
    "./telemetry": "./src/telemetry/mod.ts",
    "./config": "./src/config/mod.ts",
    "./contracts/v1": "./src/contracts/v1/mod.ts",
    "./streams": "./src/streams/mod.ts",
    "./presets": "./src/presets/mod.ts",
    "./abstracts": "./src/abstracts/mod.ts",
    "./testing": "./src/testing/mod.ts",
    "./agent": "./src/agent/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "hono": "jsr:@hono/hono@4.12.24",
    "@netscript/kv": "jsr:@netscript/kv@0.0.1-canary.1",
    "@netscript/telemetry": "jsr:@netscript/telemetry@0.0.1-canary.1",
    "zod": "jsr:@zod/zod@4.4.3"
  },
  "tasks": {
    "check": "deno check --unstable-kv mod.ts src/builders/mod.ts src/domain/mod.ts src/ports/mod.ts src/runtime/mod.ts src/adapters/mod.ts src/transports/mod.ts src/stores/mod.ts src/middleware/mod.ts src/integration/workers/mod.ts src/integration/publisher/mod.ts src/telemetry/mod.ts src/config/mod.ts src/contracts/v1/mod.ts src/streams/mod.ts src/presets/mod.ts src/abstracts/mod.ts src/testing/mod.ts src/agent/mod.ts",
    "test": "deno test --unstable-kv --allow-all",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "mod.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "**/test_utils/**"
    ]
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  }
}
