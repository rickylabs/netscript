{
  "name": "@netscript/config",
  "version": "0.0.1-alpha.3",
  "license": "MIT",
  "description": "Typed NetScript project configuration schemas, loaders, environment helpers, and scaffold constants.",
  "exports": {
    ".": "./mod.ts",
    "./merge": "./src/merge/mod.ts",
    "./paths": "./src/paths/mod.ts",
    "./schema/plugins": "./src/schema/plugins/mod.ts"
  },
  "imports": {
    "@std/fs": "jsr:@std/fs@^1",
    "@std/jsonc": "jsr:@std/jsonc@^1",
    "@std/path": "jsr:@std/path@^1",
    "zod": "jsr:@zod/zod@4.4.3"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "mod.ts",
      "*.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "tests/**",
      "examples/**"
    ]
  },
  "tasks": {
    "check": "deno check --unstable-kv mod.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  }
}
