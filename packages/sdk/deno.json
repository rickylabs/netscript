{
  "name": "@netscript/sdk",
  "version": "0.0.1-alpha.0",
  "description": "Service discovery, oRPC clients, and cache-backed query factories for NetScript.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./cache": "./src/cache/mod.ts",
    "./client": "./src/client/mod.ts",
    "./collections": "./src/collections/mod.ts",
    "./discovery": "./src/discovery/mod.ts",
    "./ports": "./src/ports/mod.ts",
    "./query": "./src/query/mod.ts",
    "./query-client": "./src/query-client/mod.ts",
    "./streams": "./src/streams.ts",
    "./telemetry": "./src/telemetry/mod.ts"
  },
  "tasks": {
    "check": "deno check --unstable-kv ./mod.ts ./src/cache/mod.ts ./src/client/mod.ts ./src/collections/mod.ts ./src/discovery/mod.ts ./src/ports/mod.ts ./src/query/mod.ts ./src/query-client/mod.ts ./src/streams.ts ./src/telemetry/mod.ts",
    "test": "deno test --allow-all ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@netscript/kv": "../kv/mod.ts",
    "@netscript/plugin-streams-core": "../plugin-streams-core/mod.ts",
    "@netscript/telemetry": "../telemetry/mod.ts",
    "@std/assert": "jsr:@std/assert@^1",
    "@standard-schema/spec": "jsr:@standard-schema/spec@1.1.0",
    "@orpc/client": "catalog:",
    "@orpc/client/fetch": "npm:@orpc/client@^1.14.6/fetch",
    "@orpc/client/plugins": "npm:@orpc/client@^1.14.6/plugins",
    "@orpc/client/standard": "npm:@orpc/client@^1.14.6/standard",
    "@orpc/contract": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/tanstack-query": "catalog:",
    "@orpc/zod": "catalog:",
    "@tanstack/db": "catalog:",
    "@tanstack/query-core": "catalog:",
    "@tanstack/query-db-collection": "catalog:"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  }
}
