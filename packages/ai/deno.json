{
  "name": "@netscript/ai",
  "version": "0.0.1-alpha.0",
  "description": "Zero-dependency AI engine core: domain contracts, capability ports, model registry, and composition root for NetScript's AI stack.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./anthropic": "./anthropic.ts",
    "./openai-compatible": "./openai-compatible.ts",
    "./contracts": "./src/contracts/mod.ts",
    "./ports": "./src/ports/mod.ts",
    "./testing": "./src/testing/mod.ts"
  },
  "tasks": {
    "check": "deno check --unstable-kv ./mod.ts ./anthropic.ts ./openai-compatible.ts ./src/contracts/mod.ts ./src/ports/mod.ts ./src/testing/mod.ts",
    "test": "deno test --allow-all ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@tanstack/ai-anthropic": "npm:@tanstack/ai-anthropic@^0.15.13",
    "@tanstack/ai-openai": "npm:@tanstack/ai-openai@^0.15.10"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "deno.json",
      "README.md",
      "docs/**/*.md"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
