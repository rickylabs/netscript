{
  "name": "@netscript/aspire",
  "version": "0.0.1-alpha.16",
  "description": "Config parsing, contribution ports, and SDK-agnostic helpers for Aspire TypeScript AppHost.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./config": "./config.ts",
    "./schema": "./schema.ts",
    "./types": "./types.ts",
    "./constants": "./constants.ts",
    "./application": "./src/application/mod.ts",
    "./adapters": "./src/adapters/mod.ts",
    "./testing": "./src/testing/mod.ts",
    "./public": "./src/public/mod.ts"
  },
  "imports": {
    "zod": "jsr:@zod/zod@4.4.3",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "check": "deno check --unstable-kv mod.ts",
    "test": "deno test --allow-all tests/",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts"
    ]
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
