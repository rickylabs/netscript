{
  "$schema": "./appsettings.schema.json",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning"
    }
  },
  "NetScript": {
    "Name": "test-app",
    "Version": "1.0.0",
    "AspireProject": "dotnet/AppHost",
    "PrimaryDatabase": "postgres",
    "PrimaryCache": "garnet",
    "Otel": {
      "HttpEndpoint": "http://localhost:4318",
      "Protocol": "http/protobuf"
    },
    "Defaults": {
      "Deno": {
        "Permissions": [
          "--allow-net",
          "--allow-env",
          "--allow-read",
          "--allow-sys"
        ],
        "WatchMode": true
      }
    },
    "Services": {
      "users": {
        "Runtime": "deno",
        "Port": 3000,
        "Entrypoint": "src/main.ts",
        "Workdir": "services/users"
      },
      "products": {
        "Runtime": "deno",
        "Port": 3001,
        "Entrypoint": "src/main.ts",
        "Workdir": "services/products"
      },
      "orders": {
        "Runtime": "deno",
        "Port": 3002,
        "Entrypoint": "src/main.ts",
        "Workdir": "services/orders",
        "ServiceReferences": ["users", "products"]
      }
    },
    "Apps": {
      "frontend": {
        "Enabled": false,
        "Runtime": "deno",
        "Type": "app",
        "WatchMode": false,
        "Prebuild": "build",
        "Workdir": "apps/frontend",
        "Permissions": [
          "--allow-net",
          "--allow-env",
          "--allow-read",
          "--allow-write",
          "--allow-sys"
        ],
        "RequiresKv": true,
        "ServiceReferences": ["users", "products", "orders"],
        "PluginReferences": ["workers-api", "sagas-api", "triggers-api"]
      },
      "playground": {
        "Runtime": "deno",
        "Type": "app",
        "WatchMode": false,
        "Prebuild": "build",
        "Workdir": "apps/playground",
        "Permissions": [
          "--allow-net",
          "--allow-env",
          "--allow-read",
          "--allow-write",
          "--allow-sys"
        ],
        "RequiresKv": true,
        "ServiceReferences": ["users", "products", "orders"],
        "PluginReferences": [
          "workers-api",
          "sagas-api",
          "triggers-api",
          "streams"
        ],
        "Description": "Fresh RFC playground app"
      },
      "tauri": {
        "Enabled": false,
        "Type": "tauri",
        "Runtime": "deno",
        "Workdir": "apps/frontend",
        "Port": 5000,
        "TaskName": "dev:desktop",
        "Description": "Tauri desktop app",
        "Remote": "frontend",
        "RequiresKv": true,
        "ServiceReferences": ["users", "products", "orders"],
        "PluginReferences": ["workers-api", "sagas-api", "triggers-api"]
      }
    },
    "Plugins": {
      "workers-api": {
        "Enabled": true,
        "Port": 8091,
        "Entrypoint": "services/src/main.ts",
        "Workdir": "plugins/workers",
        "RequiresKv": true,
        "RequiresDb": true,
        "PluginReferences": ["streams"],
        "Description": "Workers API for job management and SSE streaming"
      },
      "sagas-api": {
        "Enabled": true,
        "Port": 8092,
        "Entrypoint": "services/src/main.ts",
        "Workdir": "plugins/sagas",
        "RequiresKv": true,
        "RequiresDb": true,
        "PluginReferences": ["streams"],
        "Description": "Sagas API for workflow management and SSE streaming"
      },
      "triggers-api": {
        "Enabled": true,
        "Port": 8093,
        "Entrypoint": "services/src/main.ts",
        "Workdir": "plugins/triggers",
        "RequiresKv": true,
        "RequiresDb": true,
        "PluginReferences": ["streams"],
        "Description": "Triggers API for management, webhooks, and SSE streaming"
      },
      "streams": {
        "Enabled": true,
        "Port": 4437,
        "Entrypoint": "services/src/main.ts",
        "Workdir": "plugins/streams",
        "Permissions": [
          "--allow-net",
          "--allow-env",
          "--allow-read",
          "--allow-write",
          "--allow-sys",
          "--allow-ffi"
        ],
        "Description": "Durable Streams server for RFC 16 end-to-end stream transport"
      }
    },
    "BackgroundProcessors": {
      "workers": {
        "Enabled": true,
        "Workdir": "workers",
        "Entrypoint": "bin/combined.ts",
        "Concurrency": 2,
        "ConcurrencyEnvVar": "WORKER_CONCURRENCY",
        "RequiresDb": true,
        "RequiresKv": true,
        "ServiceReferences": ["users", "products", "orders"],
        "PluginReferences": ["workers-api", "streams"],
        "Permissions": ["--allow-all", "--unstable-kv"],
        "Description": "Combined scheduler + worker runtime"
      },
      "sagas": {
        "Enabled": true,
        "Workdir": "sagas",
        "Entrypoint": "bin/combined.ts",
        "Concurrency": 2,
        "ConcurrencyEnvVar": "SAGA_CONCURRENCY",
        "RequiresDb": true,
        "RequiresKv": true,
        "ServiceReferences": ["users", "products", "orders"],
        "PluginReferences": ["workers-api", "sagas-api", "streams"],
        "Permissions": ["--allow-all", "--unstable-kv"],
        "Description": "Saga processor runtime"
      },
      "triggers": {
        "Enabled": true,
        "Workdir": "plugins/triggers",
        "Entrypoint": "src/runtime/trigger-processor.ts",
        "Concurrency": 10,
        "ConcurrencyEnvVar": "TRIGGER_CONCURRENCY",
        "RequiresDb": true,
        "RequiresKv": true,
        "ServiceReferences": ["users", "products", "orders"],
        "PluginReferences": [
          "workers-api",
          "sagas-api",
          "triggers-api",
          "streams"
        ],
        "WatchDirs": ["./tmp/netscript-incoming"],
        "Permissions": ["--allow-all", "--unstable-kv"],
        "Description": "Trigger processor runtime"
      },
      "benchmark": {
        "Enabled": true,
        "Entrypoint": "main.ts",
        "Workdir": "benchmark",
        "WatchMode": false,
        "Telemetry": false,
        "RequiresKv": true,
        "ServiceReferences": ["users", "products", "orders"],
        "PluginReferences": [
          "workers-api",
          "sagas-api",
          "triggers-api",
          "streams"
        ],
        "Permissions": ["--allow-all", "--unstable-kv"],
        "Description": "NetScript Framework Benchmark Tool - KV, Queue, Workers, Sagas, E2E pipeline performance evaluation"
      }
    },
    "Databases": {
      "postgres": {
        "Engine": "Postgres",
        "ImageTag": "18",
        "DatabaseName": "postgresdb",
        "DataPath": "data/postgres",
        "Persistent": true
      }
    },
    "Cache": {
      "garnet": {
        "Mode": "Container",
        "Engine": "Garnet",
        "ImageTag": "1.1.1",
        "Port": 6379,
        "DataPath": "data/garnet",
        "Description": "Unified KV + Queue + Cache + Pub/Sub"
      }
    },
    "Tools": {
      "prisma-studio": {
        "Enabled": true,
        "TaskName": "db:studio",
        "Database": "postgres",
        "Description": "Prisma Studio for database management"
      }
    }
  }
}
