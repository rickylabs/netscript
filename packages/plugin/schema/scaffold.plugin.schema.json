{
  "$id": "jsr:@netscript/plugin/schema",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "capabilities": {
      "additionalProperties": false,
      "properties": {
        "hasBackgroundWorkers": {
          "type": "boolean"
        },
        "hasDatabaseMigrations": {
          "type": "boolean"
        },
        "hasRoutes": {
          "type": "boolean"
        }
      },
      "required": [
        "hasDatabaseMigrations",
        "hasRoutes",
        "hasBackgroundWorkers"
      ],
      "type": "object"
    },
    "description": {
      "minLength": 1,
      "type": "string"
    },
    "displayName": {
      "minLength": 1,
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "officialSource": {
      "additionalProperties": false,
      "properties": {
        "backgroundDir": {
          "minLength": 1,
          "type": "string"
        },
        "backgroundEntrypoint": {
          "minLength": 1,
          "type": "string"
        },
        "backgroundPort": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        },
        "canonicalName": {
          "minLength": 1,
          "type": "string"
        },
        "dependencies": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "readOnly": true,
          "type": "array"
        },
        "permissions": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "readOnly": true,
          "type": "array"
        },
        "pluginDir": {
          "minLength": 1,
          "type": "string"
        },
        "pluginReferences": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "readOnly": true,
          "type": "array"
        },
        "requiresDb": {
          "type": "boolean"
        },
        "requiresKv": {
          "type": "boolean"
        },
        "serviceConfigKey": {
          "minLength": 1,
          "type": "string"
        },
        "serviceEntrypoint": {
          "minLength": 1,
          "type": "string"
        },
        "servicePort": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "canonicalName",
        "serviceEntrypoint",
        "serviceConfigKey",
        "servicePort",
        "backgroundPort"
      ],
      "type": "object"
    },
    "peerDependencies": {
      "additionalProperties": {
        "minLength": 1,
        "type": "string"
      },
      "propertyNames": {
        "minLength": 1,
        "type": "string"
      },
      "type": "object"
    },
    "postScripts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "args": {
            "items": {
              "type": "string"
            },
            "readOnly": true,
            "type": "array"
          },
          "export": {
            "minLength": 1,
            "pattern": "^\\.\\/(?!(?:.*(?:^|\\/)\\.\\.?)(?:\\/|$))[^\\\\\\u0000/]+(?:\\/[^\\\\\\u0000/]+)*$",
            "type": "string"
          }
        },
        "required": [
          "export"
        ],
        "type": "object"
      },
      "readOnly": true,
      "type": "array"
    },
    "provider": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "plugin",
            "background-processor"
          ],
          "type": "string"
        },
        "concurrencyEnvVar": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "defaultConcurrency": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "defaultEntrypoint": {
          "minLength": 1,
          "type": "string"
        },
        "defaultPermissions": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "readOnly": true,
          "type": "array"
        },
        "defaultRequiresDb": {
          "type": "boolean"
        },
        "defaultRequiresKv": {
          "type": "boolean"
        },
        "defaultServiceEntrypoint": {
          "minLength": 1,
          "type": "string"
        },
        "defaultTelemetry": {
          "type": "boolean"
        },
        "displayName": {
          "minLength": 1,
          "type": "string"
        },
        "infrastructureOptionalDeps": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "readOnly": true,
          "type": "array"
        },
        "infrastructureRequires": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "readOnly": true,
          "type": "array"
        },
        "kind": {
          "minLength": 1,
          "type": "string"
        },
        "pluginType": {
          "enum": [
            "background-processor",
            "api",
            "frontend",
            "utility"
          ],
          "type": "string"
        },
        "portRangeKey": {
          "minLength": 1,
          "type": "string"
        },
        "supportsConcurrency": {
          "type": "boolean"
        },
        "watchFlag": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "kind",
        "displayName",
        "category",
        "portRangeKey",
        "defaultPermissions",
        "defaultEntrypoint",
        "defaultServiceEntrypoint",
        "defaultRequiresDb",
        "defaultRequiresKv",
        "pluginType",
        "supportsConcurrency",
        "concurrencyEnvVar",
        "defaultConcurrency",
        "defaultTelemetry",
        "infrastructureRequires",
        "infrastructureOptionalDeps"
      ],
      "type": "object"
    },
    "scaffolder": {
      "additionalProperties": false,
      "properties": {
        "export": {
          "minLength": 1,
          "pattern": "^\\.\\/(?!(?:.*(?:^|\\/)\\.\\.?)(?:\\/|$))[^\\\\\\u0000/]+(?:\\/[^\\\\\\u0000/]+)*$",
          "type": "string"
        },
        "requiredPermissions": {
          "additionalProperties": false,
          "properties": {
            "net": {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "readOnly": true,
              "type": "array"
            },
            "read": {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "readOnly": true,
              "type": "array"
            },
            "write": {
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "readOnly": true,
              "type": "array"
            }
          },
          "required": [
            "net",
            "read",
            "write"
          ],
          "type": "object"
        }
      },
      "required": [
        "export",
        "requiredPermissions"
      ],
      "type": "object"
    },
    "schemaVersion": {
      "const": 1,
      "type": "number"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "name",
    "version",
    "displayName",
    "description",
    "peerDependencies",
    "capabilities",
    "scaffolder"
  ],
  "title": "NetScript plugin scaffold manifest",
  "type": "object"
}
