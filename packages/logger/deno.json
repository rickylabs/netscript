{
  "name": "@netscript/logger",
  "version": "0.0.1-alpha.0",
  "description": "Structured logging for NetScript services, packages, workers, and Hono/oRPC integrations.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./middleware": "./middleware.ts",
    "./orpc": "./orpc.ts"
  },
  "tasks": {
    "check": "deno check ./mod.ts ./middleware.ts ./orpc.ts",
    "test": "deno test --allow-env ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@logtape/logtape": "jsr:@logtape/logtape@^2.0",
    "@orpc/server/plugins": "npm:@orpc/server@^1.13.5/plugins",
    "@std/assert": "jsr:@std/assert@^1",
    "hono": "npm:hono@^4"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "deno.json",
      "README.md",
      "docs/**/*.md"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "deno.ns"
    ]
  }
}
