{
  "name": "@netscript/shared",
  "version": "0.0.1-alpha.0",
  "description": "Shared schemas, contract primitives, Zod helpers, and typed error utilities for NetScript packages.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./utils": "./utils/mod.ts"
  },
  "imports": {
    "@orpc/server": "npm:@orpc/server@^1.13.5",
    "zod": "npm:zod@^4.3.6"
  },
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "mod.ts",
      "contracts.ts",
      "utils/**/*.ts"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/test_utils/**"
    ]
  }
}
