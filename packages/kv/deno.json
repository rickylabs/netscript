{
  "name": "@netscript/kv",
  "version": "0.0.1-alpha.0",
  "description": "Reactive key-value abstraction for Redis, Deno KV, and in-memory backends.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./redis": "./redis.ts",
    "./kvdex": "./kvdex.ts"
  },
  "tasks": {
    "check": "deno check ./mod.ts ./redis.ts ./kvdex.ts",
    "test": "deno test --allow-all ./tests/"
  },
  "imports": {
    "@std/async": "jsr:@std/async@^1",
    "@std/data-structures": "jsr:@std/data-structures@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/ulid": "jsr:@std/ulid@^1",
    "@std/collections": "jsr:@std/collections@^1",
    "@netscript/logger": "../logger/mod.ts",
    "@olli/kvdex": "jsr:@olli/kvdex@^3.5.0",
    "ioredis": "npm:ioredis@^5.4.1"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "tests/"
    ]
  }
}
