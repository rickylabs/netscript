{
  "name": "@netscript/kv",
  "version": "0.0.1-beta.8",
  "description": "Reactive key-value abstraction for Redis, Deno KV, and in-memory backends.",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts",
    "./redis": "./redis.ts",
    "./kvdex": "./kvdex.ts",
    "./testing": "./src/testing/mod.ts"
  },
  "tasks": {
    "check": "deno check --unstable-kv ./mod.ts ./redis.ts ./kvdex.ts ./src/testing/mod.ts",
    "test": "deno test --allow-all ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@std/async": "jsr:@std/async@^1",
    "@std/data-structures": "jsr:@std/data-structures@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/ulid": "jsr:@std/ulid@^1",
    "@std/collections": "jsr:@std/collections@^1",
    "@olli/kvdex": "jsr:@olli/kvdex@^3.6.7"
  },
  "publish": {
    "include": [
      "**/*.ts",
      "deno.json",
      "README.md"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "tests/"
    ]
  }
}
