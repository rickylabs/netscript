{
  "name": "@netscript/mcp",
  "version": "0.0.1-beta.8",
  "description": "Token-bounded MCP tools for NetScript diagnostics, telemetry insights, docs, and CLI actions.",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./cli.ts"
  },
  "imports": {
    "@netscript/telemetry/attributes": "jsr:@netscript/telemetry@0.0.1-beta.8/attributes",
    "@netscript/telemetry/query": "jsr:@netscript/telemetry@0.0.1-beta.8/query",
    "@standard-schema/spec": "jsr:@standard-schema/spec@1.1.0",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "check": "deno check mod.ts cli.ts",
    "test": "deno test --allow-env --allow-net --allow-run --allow-read tests/",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "publish": {
    "include": ["**/*.ts", "deno.json", "README.md"],
    "exclude": ["tests/", "**/*_test.ts"]
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
