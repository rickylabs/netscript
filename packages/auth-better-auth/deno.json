{
  "name": "@netscript/auth-better-auth",
  "version": "0.0.1-alpha.0",
  "description": "better-auth integration helpers for NetScript services.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts"
  },
  "imports": {
    "@netscript/service/auth": "../service/src/auth/mod.ts",
    "better-auth": "npm:better-auth@catalog:",
    "better-auth/adapters/prisma": "npm:better-auth@catalog:/adapters/prisma",
    "hono": "jsr:@hono/hono@4.12.24",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "check": "deno check --unstable-kv ./mod.ts",
    "test": "deno test --allow-net --allow-env ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "mod.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  }
}
