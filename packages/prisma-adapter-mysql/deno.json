{
  "name": "@netscript/prisma-adapter-mysql",
  "version": "0.0.1-beta.3",
  "description": "Prisma driver adapter for MySQL and MariaDB on Deno.",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts"
  },
  "tasks": {
    "check": "deno check --unstable-kv ./mod.ts",
    "test": "deno test --allow-net --allow-env ./tests/",
    "lint": "deno lint",
    "fmt": "deno fmt --check",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "mod.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "examples/**",
      "tests/**",
      "**/*_test.ts",
      "**/*.test.ts"
    ]
  }
}
