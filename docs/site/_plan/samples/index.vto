{{ comp.hero({
  tagline: "From `netscript init` to a running, type-checked, OpenTelemetry-traced backend — services, durable workflows, and a Fresh UI in one workspace.",
  subhead: "A Deno-native backend framework where the contract you define is the client you call.",
