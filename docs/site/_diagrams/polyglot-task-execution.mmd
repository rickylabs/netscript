%% Source for assets/diagrams/polyglot-task-execution.svg
%% Rendered to a committed static SVG by the SEPARATE dev task in render.ts.
%% This file is NOT consumed by `deno task build`; the site ships the SVG only.
%% IPC reality: the handler spawns a subprocess and passes input as command-line
%% argv + env vars (TRACEPARENT / CORRELATION_ID injected via env). Output is a
%% JSON object parsed from the LAST line of stdout. There is NO stdin channel.
flowchart LR
  worker["Worker runtime<br/>(enqueues task)"] --> handler["TS handler<br/>(task handler)"]
  subgraph subprocess
    proc["deno / python / dotnet<br/>cmd / powershell / shell / exe<br/>(spawned process)"]
  end
  handler -- "spawn &middot; in: argv + env vars" --> proc
  proc -- "out: last stdout line &rarr; JSON object" --> handler
  handler -- "result" --> sink["Queue / DB<br/>(persist result)"]
