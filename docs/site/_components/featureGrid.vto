{{# Lume component — docs/site/_components/featureGrid.vto
   Responsive grid of cards; reuses comp.card markup so a card is standalone or a grid item.
   Invoke:  {{ comp.featureGrid({ items: [{ title, body, href?, icon? }, …] }) }}
   All colors key off the existing fresh-ui --ns-* tokens so it matches the chrome. #}}
{{ set cells = items || [] }}
<div class="ns-feature-grid" role="list">
  {{ for item of cells }}
    <div role="listitem">{{ comp.card(item) }}</div>
  {{ /for }}
</div>
