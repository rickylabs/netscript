<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} · NetScript Docs</title>
    <meta
      name="description"
      content="NetScript — Deno-native polyglot backend framework documentation (Diátaxis)."
    />
    <link rel="icon" href="{{ '/favicon.svg' |> url }}" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ '/styles/docs.css' |> url }}" />
    {{# Prevent flash: apply saved theme before first paint (mirrors playground _app.tsx) #}}
    <script>
      (function () {
        var t = localStorage.getItem("ns-theme");
        if (!t) {
          t = matchMedia("(prefers-color-scheme:light)").matches ? "light" : "dark";
        }
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="ns-skip-link">Skip to main content</a>

    <div class="ns-dashboard">
      <div class="ns-dashboard__sidebar-backdrop" data-sidebar-backdrop aria-hidden="true"></div>

      <aside class="ns-dashboard__sidebar" data-sidebar>
        <div class="ns-dashboard__sidebar-header">
          <a href="{{ '/' |> url }}" class="ns-topbar-brand">net<em>script</em></a>
          <span class="ns-badge ns-badge--muted">docs</span>
        </div>

        {{# docs-v5 sidebar (see _plan/10-nav-ia-redesign.md): curated lanes from
           `navLanes` over folder-derived nav.menu() subtrees. Node/page urls are
           SOURCE urls on both sides (source==source comparisons); emitted hrefs
           get the /netscript/ base via the `url` filter + base_path. #}}
        <nav class="ns-dashboard__sidebar-body" aria-label="Documentation navigation">
          {{ for laneIndex, lane of navLanes }}
            {{ if laneIndex > 0 }}
              <div class="ns-dashboard__nav-divider" role="separator"></div>
            {{ /if }}
            <div class="ns-dashboard__nav-group" role="list">
              <h3 class="ns-dashboard__nav-group-label ns-nav-lane">
                {{ lane.label }}
                <span class="ns-nav-lane__sub">{{ lane.subtitle }}</span>
              </h3>
              {{ if lane.kind === "flat" }}
                {{ for item of lane.items }}
                  {{ set isActive = url === item.href }}
                  <a
                    href="{{ item.href |> url }}"
                    role="listitem"
                    class="ns-dashboard__nav-item{{ if isActive }} is-active{{ /if }}"
                    {{ if isActive }}aria-current="page"{{ /if }}
                  >
                    <span class="ns-dashboard__nav-label">{{ item.label }}</span>
                  </a>
                {{ /for }}
              {{ else }}
                {{ for root of lane.roots }}
                  {{ set tree = nav.menu(root, navQuery, navSort) }}
                  {{ if tree && tree.data }}
                    {{ if lane.expandRoot }}
                      <a
                        href="{{ tree.data.url |> url }}"
                        role="listitem"
                        class="ns-dashboard__nav-item{{ if url === tree.data.url }} is-active{{ /if }}"
                        {{ if url === tree.data.url }}aria-current="page"{{ /if }}
                      >
                        <span class="ns-dashboard__nav-label">{{ tree.data.nav_title || tree.data.title }}</span>
                      </a>
                      {{ for child of tree.children }}
                        {{ include "nav/menu-item.vto" { item: child, currentUrl: url } }}
                      {{ /for }}
                    {{ else }}
                      {{ include "nav/menu-item.vto" { item: tree, currentUrl: url } }}
                    {{ /if }}
                  {{ /if }}
                {{ /for }}
              {{ /if }}
            </div>
          {{ /for }}
        </nav>

        <div class="ns-dashboard__sidebar-footer">
          <div class="ns-dashboard__sidebar-env">
            <span class="ns-dashboard__sidebar-env-label">netscript docs</span>
          </div>
        </div>
      </aside>

      <div class="ns-dashboard__main">
        <header class="ns-dashboard__topbar">
          <div class="ns-cluster">
            <button
              type="button"
              class="ns-icon-btn ns-mobile-trigger"
              data-sidebar-toggle
              aria-label="Toggle navigation"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="18" x2="21" y2="18" />
              </svg>
            </button>
            <div class="ns-search" id="search"></div>
          </div>
          <div class="ns-cluster ns-cluster--end">
            <span class="ns-badge ns-badge--muted" title="NetScript is alpha software">Alpha</span>
            <button
              type="button"
              class="ns-icon-btn ns-theme-toggle"
              data-theme-toggle
              aria-label="Toggle dark / light theme"
              title="Toggle dark / light theme"
            >
              <span class="ns-icon-sun" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="5" />
                  <line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" />
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                  <line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" />
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                </svg>
              </span>
              <span class="ns-icon-moon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
              </span>
            </button>
          </div>
        </header>

        <main class="ns-dashboard__content" id="main-content" tabindex="-1">
          {{ comp.breadcrumb({ url, title }) }}
          {{# AI-affordance (PR-A): plain link to this page's Markdown twin
             (built by _plugins/ai-tooling.ts). CSP-safe, no client JS. #}}
          <div class="ns-page-actions">
            <a
              class="ns-md-link"
              href="{{ (url + 'index.md') |> url }}"
              data-pagefind-ignore
              title="View this page as clean Markdown (for LLMs and agents)"
            >
              <span aria-hidden="true">&#9660;</span> View as Markdown
            </a>
          </div>
          <div class="ns-content-rail">
            <article class="ns-prose" data-pagefind-body>
              {{ content }}
            </article>
            {{# On-page TOC (right rail on desktop, collapsible on mobile). Built by JS
               from the article's h2/h3 (markdown-it-anchor adds the slug ids). With JS
               off the <nav> stays empty/hidden, so the layout degrades gracefully. #}}
            <nav class="ns-toc" data-toc aria-label="On this page" hidden>
              <button type="button" class="ns-toc__summary" data-toc-toggle aria-expanded="true">
                On this page
              </button>
              <ol class="ns-toc__list" data-toc-list></ol>
            </nav>
          </div>
          {{ comp.nextPrev({ prev, next, url }) }}
          {{ set editSourcePath = page.sourcePath }}
          {{ if editSourcePath && editSourcePath !== "(generated)" && !editSourcePath.startsWith("/reference/") }}
            {{ set editHref = "https://github.com/rickylabs/netscript/edit/main/docs/site" + editSourcePath }}
            <footer class="ns-nextprev" aria-label="Page source">
              <a class="ns-nextprev__link" href="{{ editHref }}" target="_blank" rel="noreferrer">
                <span class="ns-nextprev__dir" aria-hidden="true">GitHub</span>
                <span class="ns-nextprev__label">Edit this page</span>
              </a>
            </footer>
          {{ /if }}
        </main>
      </div>
    </div>

    {{# Theme toggle — mirrors ThemeToggle.tsx: flip data-theme, persist to ns-theme. #}}
    <script>
      (function () {
        var btn = document.querySelector("[data-theme-toggle]");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var cur = document.documentElement.getAttribute("data-theme") === "light"
            ? "light"
            : "dark";
          var next = cur === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
          localStorage.setItem("ns-theme", next);
        });
      })();
    </script>

    {{# Sidebar toggle (mobile): flip is-open / is-visible classes. #}}
    <script>
      (function () {
        var sidebar = document.querySelector("[data-sidebar]");
        var backdrop = document.querySelector("[data-sidebar-backdrop]");
        var trigger = document.querySelector("[data-sidebar-toggle]");
        if (!sidebar || !trigger) return;
        function close() {
          sidebar.classList.remove("is-open");
          if (backdrop) backdrop.classList.remove("is-visible");
        }
        trigger.addEventListener("click", function () {
          sidebar.classList.toggle("is-open");
          if (backdrop) backdrop.classList.toggle("is-visible");
        });
        if (backdrop) backdrop.addEventListener("click", close);
      })();
    </script>

    {{# Tabbed code enhancement; with JS disabled, every panel remains visible. #}}
    <script>
      (function () {
        function setup(root) {
          var tabs = Array.prototype.slice.call(root.querySelectorAll(".ns-tabbed__tab"));
          var panels = Array.prototype.slice.call(root.querySelectorAll(".ns-tabbed__panel"));
          if (!tabs.length || !panels.length) return;

          function activate(index) {
            tabs.forEach(function (tab, i) {
              var on = i === index;
              tab.classList.toggle("is-active", on);
              tab.setAttribute("aria-selected", on ? "true" : "false");
              tab.setAttribute("tabindex", on ? "0" : "-1");
            });
            panels.forEach(function (panel, i) {
              if (i === index) panel.removeAttribute("hidden");
              else panel.setAttribute("hidden", "");
            });
          }

          tabs.forEach(function (tab, i) {
            tab.addEventListener("click", function () {
              activate(i);
              if (root.hasAttribute("data-ns-runtime-group")) {
                var label = tab.getAttribute("data-ns-runtime");
                if (label) {
                  try {
                    localStorage.setItem("ns-runtime", label);
                  } catch (e) { /* storage unavailable: selection just won't persist */ }
                  syncRuntimeGroups(label, root);
                }
              }
            });
            tab.addEventListener("keydown", function (e) {
              var next = null;
              if (e.key === "ArrowRight" || e.key === "ArrowDown") next = (i + 1) % tabs.length;
              else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
                next = (i - 1 + tabs.length) % tabs.length;
              } else if (e.key === "Home") next = 0;
              else if (e.key === "End") next = tabs.length - 1;
              if (next === null) return;
              e.preventDefault();
              activate(next);
              tabs[next].focus();
            });
          });

          root.classList.add("is-enhanced");
          root._nsActivate = activate;
          activate(0);
        }

        {{# Runtime selection (comp.tabbedRuntime) persists across navigation via the
           `ns-runtime` localStorage key: on load, restore the saved runtime for every
           group; on tab click, write it back and re-sync the other groups on the page. #}}
        function syncRuntimeGroups(label, except) {
          var groups = Array.prototype.slice.call(
            document.querySelectorAll(".ns-tabbed[data-ns-runtime-group]"),
          );
          groups.forEach(function (group) {
            if (group === except || typeof group._nsActivate !== "function") return;
            var tabs = Array.prototype.slice.call(group.querySelectorAll(".ns-tabbed__tab"));
            for (var i = 0; i < tabs.length; i++) {
              if (tabs[i].getAttribute("data-ns-runtime") === label) {
                group._nsActivate(i);
                break;
              }
            }
          });
        }

        function restoreRuntime() {
          var label = null;
          try {
            label = localStorage.getItem("ns-runtime");
          } catch (e) { return; }
          if (!label) return;
          syncRuntimeGroups(label, null);
        }

        function init() {
          Array.prototype.slice.call(document.querySelectorAll(".ns-tabbed")).forEach(setup);
          restoreRuntime();
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
      })();
    </script>

    {{# Code-copy buttons: inject a "Copy" button into every <pre> in .ns-prose and
       copy the code text. No-JS safe — the button is simply absent without script. #}}
    <script>
      (function () {
        function copyText(text, btn) {
          var done = function () {
            var prev = btn.textContent;
            btn.textContent = "Copied";
            btn.classList.add("is-copied");
            setTimeout(function () {
              btn.textContent = prev;
              btn.classList.remove("is-copied");
            }, 1600);
          };
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(done, function () {});
          }
        }
        function init() {
          var pres = Array.prototype.slice.call(
            document.querySelectorAll(".ns-prose pre, .ns-tabbed__panel pre"),
          );
          pres.forEach(function (pre) {
            if (pre.querySelector(".ns-copy-btn")) return;
            var btn = document.createElement("button");
            btn.type = "button";
            btn.className = "ns-copy-btn";
            btn.textContent = "Copy";
            btn.setAttribute("aria-label", "Copy code to clipboard");
            pre.classList.add("ns-pre--copyable");
            pre.appendChild(btn);
            btn.addEventListener("click", function () {
              var code = pre.querySelector("code");
              copyText((code || pre).innerText, btn);
            });
          });
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
      })();
    </script>

    {{# On-page TOC + scroll-spy: build the right-rail TOC from the article's h2/h3
       (slug ids from markdown-it-anchor), highlight the section in view via
       IntersectionObserver. No-JS safe — the <nav> stays hidden if never populated. #}}
    <script>
      (function () {
        function init() {
          var nav = document.querySelector("[data-toc]");
          var list = document.querySelector("[data-toc-list]");
          var article = document.querySelector(".ns-prose");
          if (!nav || !list || !article) return;

          var headings = Array.prototype.slice.call(
            article.querySelectorAll("h2[id], h3[id]"),
          );
          if (headings.length < 2) return;

          var byId = {};
          headings.forEach(function (h) {
            var li = document.createElement("li");
            li.className = "ns-toc__item ns-toc__item--" + h.tagName.toLowerCase();
            var a = document.createElement("a");
            a.className = "ns-toc__link";
            a.href = "#" + h.id;
            a.textContent = h.textContent;
            a.setAttribute("data-toc-target", h.id);
            li.appendChild(a);
            list.appendChild(li);
            byId[h.id] = a;
          });

          nav.removeAttribute("hidden");

          var toggle = nav.querySelector("[data-toc-toggle]");
          if (toggle) {
            toggle.addEventListener("click", function () {
              var open = nav.classList.toggle("is-collapsed");
              toggle.setAttribute("aria-expanded", open ? "false" : "true");
            });
          }

          var current = null;
          function setActive(id) {
            if (id === current) return;
            if (current && byId[current]) byId[current].classList.remove("is-active");
            current = id;
            if (id && byId[id]) byId[id].classList.add("is-active");
          }

          if (!("IntersectionObserver" in window)) return;
          var visible = {};
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              visible[entry.target.id] = entry.isIntersecting;
            });
            var active = null;
            for (var i = 0; i < headings.length; i++) {
              if (visible[headings[i].id]) {
                active = headings[i].id;
                break;
              }
            }
            if (active) setActive(active);
          }, { rootMargin: "0px 0px -70% 0px", threshold: 0 });
          headings.forEach(function (h) {
            observer.observe(h);
          });
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
