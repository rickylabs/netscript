<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} · NetScript Docs</title>
    <meta
      name="description"
      content="NetScript — Deno-native polyglot backend framework documentation (Diátaxis)."
    />
    <link rel="icon" href="{{ '/favicon.svg' |> url }}" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ '/styles/docs.css' |> url }}" />
    {{# Prevent flash: apply saved theme before first paint (mirrors playground _app.tsx) #}}
    <script>
      (function () {
        var t = localStorage.getItem("ns-theme");
        if (!t) {
          t = matchMedia("(prefers-color-scheme:light)").matches ? "light" : "dark";
        }
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="ns-skip-link">Skip to main content</a>

    <div class="ns-dashboard">
      <div class="ns-dashboard__sidebar-backdrop" data-sidebar-backdrop aria-hidden="true"></div>

      <aside class="ns-dashboard__sidebar" data-sidebar>
        <div class="ns-dashboard__sidebar-header">
          <a href="{{ '/' |> url }}" class="ns-topbar-brand">net<em>script</em></a>
          <span class="ns-badge ns-badge--muted">docs</span>
        </div>

        {{# Base-prefix the current page url so it matches itemUrl (also base-prefixed
           via the `url` filter); the bare `url` page var is the non-prefixed source
           url, so comparing it directly never matches (Gate 4 active-highlight). #}}
        {{ set homeUrl = "/" |> url }}
        {{ set pageUrl = url |> url }}
        <nav class="ns-dashboard__sidebar-body" aria-label="Documentation navigation">
          {{ for sectionIndex, section of navSections }}
            {{ if sectionIndex > 0 }}
              <div class="ns-dashboard__nav-divider" role="separator"></div>
            {{ /if }}
            <div class="ns-dashboard__nav-group" role="list">
              <span class="ns-dashboard__nav-group-label">{{ section.label }}</span>
              {{ for item of section.items }}
                {{ set itemUrl = item.href |> url }}
                {{ set isActive = pageUrl === itemUrl }}
                {{ if itemUrl !== homeUrl && pageUrl.startsWith(itemUrl) }}
                  {{ set isActive = true }}
                {{ /if }}
                <a
                  href="{{ itemUrl }}"
                  role="listitem"
                  class="ns-dashboard__nav-item{{ if isActive }} is-active{{ /if }}"
                  {{ if isActive }}aria-current="page"{{ /if }}
                >
                  <span class="ns-dashboard__nav-icon" aria-hidden="true">{{ item.icon }}</span>
                  <span class="ns-dashboard__nav-label">{{ item.label }}</span>
                </a>
              {{ /for }}
            </div>
          {{ /for }}
        </nav>

        <div class="ns-dashboard__sidebar-footer">
          <div class="ns-dashboard__sidebar-env">
            <span class="ns-dashboard__sidebar-env-label">netscript docs</span>
          </div>
        </div>
      </aside>

      <div class="ns-dashboard__main">
        <header class="ns-dashboard__topbar">
          <div class="ns-cluster">
            <button
              type="button"
              class="ns-icon-btn ns-mobile-trigger"
              data-sidebar-toggle
              aria-label="Toggle navigation"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="18" x2="21" y2="18" />
              </svg>
            </button>
            <div class="ns-search" id="search"></div>
          </div>
          <div class="ns-cluster ns-cluster--end">
            <span class="ns-badge ns-badge--muted" title="NetScript is alpha software">Alpha</span>
            <button
              type="button"
              class="ns-icon-btn ns-theme-toggle"
              data-theme-toggle
              aria-label="Toggle dark / light theme"
              title="Toggle dark / light theme"
            >
              <span class="ns-icon-sun" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="5" />
                  <line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" />
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                  <line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" />
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                </svg>
              </span>
              <span class="ns-icon-moon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
              </span>
            </button>
          </div>
        </header>

        <main class="ns-dashboard__content" id="main-content" tabindex="-1">
          {{ comp.breadcrumb({ url, navSections, title }) }}
          <article class="ns-prose" data-pagefind-body>
            {{ content }}
          </article>
          {{ comp.nextPrev({ prev, next }) }}
          {{ set editSourcePath = page.sourcePath }}
          {{ if editSourcePath && editSourcePath !== "(generated)" && !editSourcePath.startsWith("/reference/") }}
            {{ set editHref = "https://github.com/rickylabs/netscript/edit/main/docs/site" + editSourcePath }}
            <footer class="ns-nextprev" aria-label="Page source">
              <a class="ns-nextprev__link" href="{{ editHref }}" target="_blank" rel="noreferrer">
                <span class="ns-nextprev__dir" aria-hidden="true">GitHub</span>
                <span class="ns-nextprev__label">Edit this page</span>
              </a>
            </footer>
          {{ /if }}
        </main>
      </div>
    </div>

    {{# Theme toggle — mirrors ThemeToggle.tsx: flip data-theme, persist to ns-theme. #}}
    <script>
      (function () {
        var btn = document.querySelector("[data-theme-toggle]");
        if (!btn) return;
        btn.addEventListener("click", function () {
          var cur = document.documentElement.getAttribute("data-theme") === "light"
            ? "light"
            : "dark";
          var next = cur === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", next);
          localStorage.setItem("ns-theme", next);
        });
      })();
    </script>

    {{# Sidebar toggle (mobile): flip is-open / is-visible classes. #}}
    <script>
      (function () {
        var sidebar = document.querySelector("[data-sidebar]");
        var backdrop = document.querySelector("[data-sidebar-backdrop]");
        var trigger = document.querySelector("[data-sidebar-toggle]");
        if (!sidebar || !trigger) return;
        function close() {
          sidebar.classList.remove("is-open");
          if (backdrop) backdrop.classList.remove("is-visible");
        }
        trigger.addEventListener("click", function () {
          sidebar.classList.toggle("is-open");
          if (backdrop) backdrop.classList.toggle("is-visible");
        });
        if (backdrop) backdrop.addEventListener("click", close);
      })();
    </script>

    {{# Tabbed code enhancement; with JS disabled, every panel remains visible. #}}
    <script>
      (function () {
        function setup(root) {
          var tabs = Array.prototype.slice.call(root.querySelectorAll(".ns-tabbed__tab"));
          var panels = Array.prototype.slice.call(root.querySelectorAll(".ns-tabbed__panel"));
          if (!tabs.length || !panels.length) return;

          function activate(index) {
            tabs.forEach(function (tab, i) {
              var on = i === index;
              tab.classList.toggle("is-active", on);
              tab.setAttribute("aria-selected", on ? "true" : "false");
              tab.setAttribute("tabindex", on ? "0" : "-1");
            });
            panels.forEach(function (panel, i) {
              if (i === index) panel.removeAttribute("hidden");
              else panel.setAttribute("hidden", "");
            });
          }

          tabs.forEach(function (tab, i) {
            tab.addEventListener("click", function () {
              activate(i);
            });
            tab.addEventListener("keydown", function (e) {
              var next = null;
              if (e.key === "ArrowRight" || e.key === "ArrowDown") next = (i + 1) % tabs.length;
              else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
                next = (i - 1 + tabs.length) % tabs.length;
              } else if (e.key === "Home") next = 0;
              else if (e.key === "End") next = tabs.length - 1;
              if (next === null) return;
              e.preventDefault();
              activate(next);
              tabs[next].focus();
            });
          });

          root.classList.add("is-enhanced");
          activate(0);
        }

        function init() {
          Array.prototype.slice.call(document.querySelectorAll(".ns-tabbed")).forEach(setup);
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
