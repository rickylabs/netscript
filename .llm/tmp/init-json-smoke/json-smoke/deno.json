{
  "workspace": [
    "./apps/dashboard",
    "./contracts",
    "./plugins"
  ],
  "nodeModulesDir": "auto",
  "unstable": [
    "raw-imports",
    "kv"
  ],
  "tasks": {
    "dev": "deno run --allow-all apps/dashboard/main.ts",
    "check": "deno check apps/**/*.ts services/**/*.ts contracts/**/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "test": "deno test --allow-all"
  },
  "exclude": [
    "**/node_modules",
    "**/.data",
    "dotnet",
    "**/.git",
    "aspire/.aspire",
    "aspire/.helpers",
    "**/.generated"
  ],
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "dom",
      "deno.ns",
      "deno.unstable"
    ]
  }
}
