/** Split a Markdown body into sections keyed by H2 heading text (lowercased, 
trimmed). */
function sectionBodies(lines: string[]): Map<string, string> {
  const sections = new Map<string, string>();
  let current: string | null = null;
  let buf: string[] = [];
  const flush = () => {
    if (current !== null) sections.set(current, buf.join('\n'));
  };
  for (const line of lines) {
    const m = /^##\s+(.+?)\s*$/.exec(line);
    if (m) {
      flush();
      current = m[1].toLowerCase();
      buf = [];
    } else if (current !== null) {
      buf.push(line);
    }
  }
  flush();
  return sections;
}

function getSection(sections: Map<string, string>, ...names: string[]): string |
null {
  for (const name of names) {
    const body = sections.get(name.toLowerCase());
    if (body !== undefined) return body;
  }
  return null;
}

const FENCE_RE = /```[\s\S]*?```/;
const LINK_RE = /\[[^\]]+\]\([^)]+\)/;

function checkContent(text: string): Violation[] {
