{
  "workspace": [],
  "nodeModulesDir": "auto",
  "tasks": {
    "check": "deno check --no-lock --unstable-kv main.tsx client.ts vite.config.ts routes/**/*.tsx islands/**/*.tsx",
    "dev": "vite --host 127.0.0.1"
  },
  "imports": {
    "@/": "./",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1",
    "@zag-js/combobox": "npm:@zag-js/combobox@1.41.2",
    "@zag-js/preact": "npm:@zag-js/preact@1.41.2",
    "esbuild": "npm:esbuild@^0.25",
    "fresh": "jsr:@fresh/core@^2",
    "preact": "npm:preact@^10",
    "preact/hooks": "npm:preact@^10/hooks",
    "vite": "npm:vite@^7"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["dom", "dom.iterable", "deno.ns"]
  }
}
