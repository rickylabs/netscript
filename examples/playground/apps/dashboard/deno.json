{
  "name": "@playground/dashboard",
  "version": "0.0.0",
  "exports": "./main.ts",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "deno run -A npm:vite --configLoader native",
    "build": "deno run -A npm:vite build",
    "serve": "deno run -A npm:vite preview",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@app/": "./",
    "@playground/contracts": "../../contracts/mod.ts",
    "@netscript/fresh": "jsr:@netscript/fresh@^1.0.0",
    "@netscript/fresh/builders": "jsr:@netscript/fresh@^1.0.0/builders",
    "@netscript/fresh/query": "jsr:@netscript/fresh@^1.0.0/query",
    "@netscript/fresh/route": "jsr:@netscript/fresh@^1.0.0/route",
    "@netscript/fresh/server": "jsr:@netscript/fresh@^1.0.0/server",
    "@netscript/fresh/vite": "jsr:@netscript/fresh@^1.0.0/vite",
    "@netscript/fresh-ui": "jsr:@netscript/fresh-ui@^1.0.0",
    "@netscript/sdk": "jsr:@netscript/sdk@^1.0.0",
    "@netscript/sdk/client": "jsr:@netscript/sdk@^1.0.0/client",
    "@netscript/sdk/query": "jsr:@netscript/sdk@^1.0.0/query",
    "@netscript/sdk/query-client": "jsr:@netscript/sdk@^1.0.0/query-client",
    "fresh": "jsr:@fresh/core@^2.3.0",
    "preact": "npm:preact@^10.29.1",
    "preact/hooks": "npm:preact@^10.29.1/hooks",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "tailwindcss": "npm:tailwindcss@^4.2.2",
    "vite": "npm:vite@^7.1.4",
    "vite/client": "npm:vite@^7.1.4/client"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
