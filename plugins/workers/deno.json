{
  "name": "@netscript/plugin-workers",
  "version": "0.0.1-alpha.0",
  "description": "NetScript plugin for background job scheduling, task execution, and worker API endpoints.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./aspire": "./src/aspire/mod.ts",
    "./cli": "./src/cli/composition/main.ts",
    "./contracts": "./contracts/v1/mod.ts",
    "./scaffolding": "./src/scaffolding/mod.ts",
    "./services": "./services/src/main.ts",
    "./streams": "./streams/mod.ts",
    "./streams/server": "./streams/server.ts",
    "./worker": "./worker/mod.ts"
  },
  "imports": {
    "@netscript/fresh/streams": "../../packages/fresh/src/runtime/streams/mod.ts",
    "@netscript/aspire": "../../packages/aspire/src/public/mod.ts",
    "@netscript/plugin-streams": "../streams/mod.ts",
    "@netscript/plugin-streams-core": "../../packages/plugin-streams-core/mod.ts",
    "@netscript/plugin-workers-core": "../../packages/plugin-workers-core/mod.ts",
    "@netscript/plugin-workers-core/contracts/v1": "../../packages/plugin-workers-core/src/contracts/v1/mod.ts",
    "@netscript/plugin-workers-core/executor": "../../packages/plugin-workers-core/src/executor/mod.ts",
    "@netscript/plugin-workers-core/registry": "../../packages/plugin-workers-core/src/registry/mod.ts",
    "@netscript/plugin-workers-core/runtime": "../../packages/plugin-workers-core/src/runtime/mod.ts",
    "@netscript/plugin-workers-core/state": "../../packages/plugin-workers-core/src/state/mod.ts",
    "@netscript/plugin-workers-core/streams": "../../packages/plugin-workers-core/src/streams/mod.ts",
    "@netscript/plugin": "../../packages/plugin/mod.ts",
    "@netscript/kv": "../../packages/kv/mod.ts",
    "@netscript/queue": "../../packages/queue/mod.ts",
    "@netscript/cron": "../../packages/cron/mod.ts",
    "@netscript/telemetry": "../../packages/telemetry/mod.ts",
    "@netscript/service": "../../packages/service/mod.ts",
    "@netscript/contracts": "../../packages/contracts/mod.ts",
    "@std/async": "jsr:@std/async@^1",
    "@std/path": "jsr:@std/path@^1",
    "@orpc/contract": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/server/fetch": "npm:@orpc/server@^1.14.6/fetch",
    "@orpc/server/plugins": "npm:@orpc/server@^1.14.6/plugins",
    "@orpc/openapi": "catalog:",
    "@orpc/openapi/fetch": "npm:@orpc/openapi@^1.14.6/fetch",
    "@orpc/zod": "catalog:",
    "@orpc/zod/zod4": "npm:@orpc/zod@^1.14.6/zod4",
    "@standard-schema/spec": "jsr:@standard-schema/spec@1.1.0",
    "hono": "jsr:@hono/hono@4.12.24",
    "hono/cors": "jsr:@hono/hono@4.12.24/cors",
    "zod": "jsr:@zod/zod@4.4.3",
    "@tanstack/db": "catalog:",
    "@durable-streams/client": "catalog:",
    "@durable-streams/state": "catalog:",
    "@durable-streams/state/db": "npm:@durable-streams/state@^0.3.1/db"
  },
  "tasks": {
    "check": "deno check --unstable-kv mod.ts src/aspire/mod.ts src/cli/composition/main.ts contracts/v1/mod.ts src/scaffolding/mod.ts services/src/main.ts streams/mod.ts streams/server.ts worker/mod.ts",
    "test": "deno test --allow-all",
    "dev": "deno run --allow-net --allow-env --allow-read --watch services/src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read services/src/main.ts",
    "workers:e2e": "deno run --allow-net --allow-env src/e2e/probes/health.ts && deno run --allow-read verify-plugin.ts",
    "test:api": "deno run --allow-net --allow-env test-api.ts",
    "publish:dry-run": "deno publish --dry-run --allow-dirty"
  },
  "publish": {
    "include": [
      "README.md",
      "deno.json",
      "scaffold.plugin.json",
      "scaffold.runtime.json",
      "mod.ts",
      "bin/**/*.ts",
      "docs/**/*.md",
      "src/**/*.ts",
      "src/scaffolding/templates/**/*",
      "contracts/**/*.ts",
      "services/**/*.ts",
      "streams/**/*.ts",
      "worker/**/*.ts",
      "jobs/**/*.ts",
      "database/**/*.prisma"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "**/test_utils/**"
    ]
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  }
}
